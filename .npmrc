; next-contentlayer@0.3.4 declares peer deps on next ^12 || ^13, but the
; project ships Next 16 + React 19. Until contentlayer publishes a
; compatible release (or we migrate to content-collections), tell npm to
; use the legacy peer-dep resolver instead of failing with ERESOLVE.
; This setting also applies to Vercel's `npm install` step.
legacy-peer-deps=true
