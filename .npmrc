; The image-upscaler dependency chain has a strict peer-dep mismatch:
;   @upscalerjs/default-model@1.0.0 requires @tensorflow/tfjs ~4.11.0
;   but the project ships @tensorflow/tfjs ^4.22.0 (used elsewhere).
; Until upscaler publishes a version compatible with current tfjs, tell
; npm to use the legacy peer-dep resolver instead of failing with
; ERESOLVE. Vercel reads this file during its `npm install` step too.
legacy-peer-deps=true
